---
/**
 * NewsletterSignup.astro — Email signup form for NilaTales newsletter.
 *
 * Uses Formspree (or similar) for zero-backend form handling.
 * Placed on homepage (§9 area) and story pages (below body).
 *
 * Design: clay-raised card, twilight accent CTA, paper-50 background.
 * Tamil-first copy with English subtitle.
 */
interface Props {
  /** Formspree form ID (set once, used everywhere) */
  formId?: string;
  /** Heading in Tamil */
  headingTa?: string;
  /** Heading in English */
  headingEn?: string;
  /** Subtitle */
  subtitle?: string;
}

const {
  formId = 'nilatales-newsletter', // replace with actual Formspree ID
  headingTa = 'கதைகளை மிஸ் செய்யாதீர்கள்',
  headingEn = 'Never miss a story',
  subtitle = 'Get new Tamil bedtime stories delivered to your inbox every week.',
} = Astro.props;
---

<section class="py-12 md:py-16" aria-label="Newsletter signup">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="clay-card rounded-2xl bg-paper-100 border border-paper-200 p-6 md:p-8 max-w-lg mx-auto text-center">

      <!-- Envelope icon -->
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-twilight-50 text-twilight-500 mb-4" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>

      <h2 class="font-rounded-ta text-xl md:text-2xl font-bold text-kohl-700 mb-1">
        {headingTa}
      </h2>
      <p class="font-rounded text-base font-semibold text-twilight-500 mb-2">
        {headingEn}
      </p>
      <p class="font-rounded text-sm text-kohl-500 mb-6 leading-relaxed">
        {subtitle}
      </p>

      <form
        action={`https://formspree.io/f/${formId}`}
        method="POST"
        class="flex flex-col sm:flex-row gap-3 items-stretch"
      >
        <!-- Honeypot anti-spam -->
        <div class="hidden" aria-hidden="true">
          <label for="newsletter-bot">Leave this blank</label>
          <input type="text" id="newsletter-bot" name="_gotcha" tabindex="-1" autocomplete="off" />
        </div>

        <div class="flex-1">
          <label for="newsletter-email" class="sr-only">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            name="email"
            required
            placeholder="you@example.com"
            autocomplete="email"
            class="w-full px-4 py-3 rounded-xl border border-paper-300 bg-paper-50 font-rounded text-sm text-kohl-900 placeholder:text-paper-400 focus:outline-none focus:ring-2 focus:ring-twilight-500 focus:border-transparent transition-colors min-h-[44px]"
          />
        </div>

        <button
          type="submit"
          class="btn-clay-primary whitespace-nowrap"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4z"/></svg>
          Subscribe
        </button>
      </form>

      <p class="font-rounded text-xs text-paper-400 mt-3">
        No spam. Unsubscribe anytime. தனியுரிமை உங்களுக்கு.
      </p>
    </div>
  </div>
</section>