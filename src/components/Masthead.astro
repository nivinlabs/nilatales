---
/**
 * Masthead.astro — newspaper nameplate + Tamil date + Vol/Issue + hairline.
 *
 * DESIGN.md §6 Masthead.
 * Shown at the very top of every page, above the nav.
 */
---
<header class="w-full bg-paper-50 pt-6 pb-0">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <!-- Top row: Vol/Issue · date · ISSN -->
    <div class="flex items-center justify-between mb-3">
      <span class="font-mono-editorial">VOL 1 · ISSUE 12</span>
      <span class="font-mono-editorial">21 ஜூன் 2026</span>
      <span class="font-mono-editorial">ISSN 2026–1247</span>
    </div>

    <!-- Hairline rule -->
    <div class="border-t border-kohl-700 border-t-2 mb-3"></div>

    <!-- Nameplate -->
    <div class="text-center mb-1">
      <h1 class="font-display text-display text-[2.5rem] sm:text-5xl font-black tracking-tight text-kohl-900 leading-none"
          style="font-optical-sizing:auto">
        நிலா கதைகள்
      </h1>
      <p class="font-display text-display italic text-lg sm:text-xl font-light text-kohl-500 tracking-wide"
         style="font-optical-sizing:auto">
        NilaTales — bedtime stories in Tamil
      </p>
    </div>

    <!-- Second hairline -->
    <div class="border-t border-paper-300 mt-3"></div>

    <!-- Tagline / deck (below nameplate) -->
    <p class="text-center font-mono-editorial text-[11px] tracking-widest uppercase text-kohl-300 mt-2 mb-0">
      Illustrated Tamil stories for children · Tamil children's publishing
    </p>

  </div>
</header>
