---
/**
 * Masthead.astro — clean brand header (no newspaper chrome).
 *
 * Logo mark + site name + tagline. Soft, rounded, claymorphism.
 */
---
<header class="w-full bg-paper-50 pt-8 pb-4">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between gap-4">

    <!-- Logo + name -->
    <a href="/" class="flex items-center gap-3 group" aria-label="NilaTales — Home">
      <!-- Moon logo mark (SVG) -->
      <span class="clay-raised flex items-center justify-center w-12 h-12 rounded-2xl bg-twilight-50 flex-shrink-0 group-hover:scale-105 transition-transform duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-twilight-500" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </span>
      <div class="flex flex-col">
        <span class="font-rounded-ta text-2xl font-bold text-kohl-900 leading-none tracking-tight">
          நிலா கதைகள்
        </span>
        <span class="font-rounded text-sm text-kohl-500 leading-none mt-1">
          NilaTales
        </span>
      </div>
    </a>

    <!-- Right: date + bedtime toggle -->
    <div class="flex items-center gap-3">
      <span class="font-rounded text-sm text-kohl-300 hidden sm:block">
        {new Date().toLocaleDateString('ta-IN', { day: 'numeric', month: 'short', year: 'numeric' })}
      </span>
    </div>

  </div>
</header>