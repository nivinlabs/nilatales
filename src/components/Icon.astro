---
/**
 * Icon.astro — Lucide icon wrapper (inline SVG, no JS bundle).
 *
 * Usage:
 *   <Icon name="play" size={20} class="text-twilight-500" />
 *   <Icon name="moon" size={16} label="Bedtime mode" />
 *
 * 12 icons implemented (expand as needed):
 *   play | pause | chevron-right | chevron-left | search
 *   menu | x | moon | sun | file-text | headphones
 *   arrow-right | clock | volume-2 | rss | user | users | cake
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  label?: string; /* accessible name for icon-only buttons */
  strokeWidth?: number;
}
const {
  name,
  size = 20,
  class: extra = '',
  label,
  strokeWidth = 1.75,
} = Astro.props;

// Lucide path data for the 12 icons
const icons: Record<string, string> = {
  play: 'M5.3 3.6a1 1 0 0 0-1.5 1.3v14.2a1 1 0 0 0 1.5 1.3l11-7.1a1 1 0 0 0 0-1.7l-11-7.1z M15 6.3l6 3.8-6 3.8v-7.6z',
  pause: 'M6 4h4v14H6V4zm8 0h4v14h-4V4z',
  'chevron-right': 'M9 18l6-6-6-6',
  'chevron-left': 'M15 18l-6-6 6-6',
  search: 'M21 21l-4.35-4.35M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z',
  menu: 'M3 12h18M3 6h18M3 18h18',
  x: 'M18 6L6 18M6 6l12 12',
  moon: 'M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z',
  sun: 'M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41M12 6a6 6 0 1 0 0 12 6 6 0 0 0 0-12z',
  'file-text': 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  headphones: 'M3 18v-6a9 9 0 0 1 18 0v6M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3v5zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3v5z',
  'arrow-right': 'M5 12h14m-7-7l7 7-7 7',
  clock: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM12 6v6l4 2',
  'volume-2': 'M11 5L6 9H2v6h4l5 4V5zM19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07',
  rss: 'M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16',
  user: 'M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8z',
  users: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  cake: 'M20 21v-7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v7M8 3V1m8 2V1m-9 4h.01M5 3h14a2 2 0 0 1 2 2v2a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V5a2 2 0 0 1 2-2z',
  'external-link': 'M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14L21 3',
};

const path = icons[name];
const Tag = label ? 'button' : 'span';
---
<Tag
  class:list={['inline-flex items-center justify-center flex-shrink-0', extra]}
  aria-label={label}
  title={label}
  role={label ? 'button' : undefined}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width={size}
    height={size}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden={!label ? 'true' : undefined}
    style="display:inline-block;vertical-align:middle"
  >
    {path ? <path d={path} /> : <circle cx="12" cy="12" r="10" />)}
  </svg>
</Tag>
