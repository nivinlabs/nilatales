---
/**
 * ShareButtons — WhatsApp, Facebook, Twitter/X share buttons for story pages.
 * Uses Web Share API on mobile with a fallback to individual share links.
 * Positioned after story content for sharing.
 */
interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url, description = '' } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(url);
const encodedDesc = encodeURIComponent(description);

const whatsappUrl = `https://api.whatsapp.com/send?text=${encodedTitle}%20${encodedUrl}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
const twitterUrl = `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`;
---

<div class="share-buttons flex flex-col gap-3 mt-8 pt-6 border-t border-paper-300" data-share-container>
  <p class="font-rounded font-semibold text-sm text-kohl-700 mb-1">
    இந்தக் கதையைப் பகிிவோம் · Share this story
  </p>
  <div class="flex flex-wrap gap-3">
    <!-- WhatsApp -->
    <a
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-green-50 border border-green-200 text-green-700 font-rounded text-sm font-semibold hover:bg-green-100 hover:border-green-300 transition-colors min-h-[44px]"
      aria-label="Share on WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Facebook -->
    <a
      href={facebookUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-blue-50 border border-blue-200 text-blue-700 font-rounded text-sm font-semibold hover:bg-blue-100 hover:border-blue-300 transition-colors min-h-[44px]"
      aria-label="Share on Facebook"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
      </svg>
      Facebook
    </a>

    <!-- Twitter / X -->
    <a
      href={twitterUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-kohl-50 border border-kohl-200 text-kohl-700 font-rounded text-sm font-semibold hover:bg-kohl-100 hover:border-kohl-300 transition-colors min-h-[44px]"
      aria-label="Share on X (Twitter)"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
      X / Twitter
    </a>

    <!-- Native share (mobile) -->
    <button
      type="button"
      class="share-native inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-twilight-50 border border-twilight-200 text-twilight-700 font-rounded text-sm font-semibold hover:bg-twilight-100 hover:border-twilight-300 transition-colors min-h-[44px]"
      aria-label="Share this story"
      data-share-title={title}
      data-share-url={url}
      data-share-text={description}
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>
      More…
    </button>
  </div>
</div>

<script>
  // Hide native share button if Web Share API is not supported
  const nativeBtn = document.querySelector('.share-native');
  if (nativeBtn && !navigator.share) {
    nativeBtn.remove();
  } else if (nativeBtn) {
    nativeBtn.addEventListener('click', async () => {
      const btn = nativeBtn as HTMLButtonElement;
      try {
        await navigator.share({
          title: btn.dataset.shareTitle || '',
          url: btn.dataset.shareUrl || window.location.href,
          text: btn.dataset.shareText || '',
        });
      } catch {
        // User cancelled or share failed — no action needed
      }
    });
  }
</script>