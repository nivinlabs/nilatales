---
/**
 * InstagramFeed.astro — Instagram feed widget for @nitvitalks.
 *
 * Shows a link to the Instagram profile with a static preview grid.
 * No Instagram API calls — uses placeholder images with lazy loading.
 * Design: matches the NilaTales clay/paper aesthetic.
 */
interface Props {
  /** Instagram username (without @) */
  username?: string;
  /** Number of preview slots to show */
  count?: number;
}

const {
  username = 'nitvitalks',
  count = 6,
} = Astro.props;

// Placeholder grid — static slots representing future real posts
const slots = Array.from({ length: count }, (_, i) => i + 1);
---

<section class="py-12 md:py-16" aria-label="Instagram">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">

    <div class="flex items-center gap-3 mb-6">
      <div class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-rose-50" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </div>
      <div>
        <h2 class="font-rounded-ta text-lg font-bold text-kohl-700">
          @{username}
        </h2>
        <p class="font-rounded text-xs text-kohl-500">Follow us on Instagram for story previews & activities</p>
      </div>
    </div>

    <!-- Instagram grid: 3 columns on desktop, 2 on mobile -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
      {slots.map((slot) => (
        <a
          href={`https://www.instagram.com/${username}/`}
          target="_blank"
          rel="noopener noreferrer"
          class="aspect-square rounded-xl bg-paper-100 border border-paper-200 flex items-center justify-center hover:border-twilight-300 hover:bg-twilight-50 transition-colors group overflow-hidden"
          aria-label={`Instagram post ${slot}`}
        >
          <div class="flex flex-col items-center gap-2 text-paper-400 group-hover:text-twilight-500 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
            </svg>
            <span class="font-rounded text-xs">Story preview</span>
          </div>
        </a>
      ))}
    </div>

    <a
      href={`https://www.instagram.com/${username}/`}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 font-rounded font-semibold text-sm text-twilight-500 hover:text-twilight-700 transition-colors mt-4 min-h-[44px]"
    >
      Follow on Instagram
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/></svg>
    </a>

  </div>
</section>