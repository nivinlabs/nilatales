---
/**
 * InstagramFeed.astro — Instagram follow CTA for @nitvitalks.
 *
 * Clean card linking to Instagram profile. No fake placeholder grid —
 * just a visually appealing CTA with Instagram branding.
 */
interface Props {
  username?: string;
}

const {
  username = 'nitvitalks',
} = Astro.props;
---

<section class="py-12 md:py-16" aria-label="Instagram">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <a
      href={`https://www.instagram.com/${username}/`}
      target="_blank"
      rel="noopener noreferrer"
      class="clay-card flex flex-col sm:flex-row items-center gap-6 p-6 md:p-8 rounded-2xl bg-paper-50 border border-paper-200 hover:border-twilight-300 transition-colors duration-200 group"
    >
      <!-- Instagram icon -->
      <div class="clay-raised flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-pink-100 via-rose-100 to-amber-100 flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="text-rose-600" aria-hidden="true">
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </div>

      <!-- Text -->
      <div class="flex-1 text-center sm:text-left">
        <h2 class="font-rounded-ta text-lg font-bold text-kohl-700 group-hover:text-rose-600 transition-colors">
          @{username}
        </h2>
        <p class="font-rounded text-sm text-kohl-500 mt-1">
          Story illustrations, coloring pages, and kids' activities
        </p>
        <p class="font-rounded-ta text-sm text-kohl-500 mt-2 leading-relaxed">
          கதை ஓவியங்கள், நிறமூழ்ய பக்கங்கள், மற்றும் குழந்தைகளுக்கான செயல்பாடுகள் — follow us for weekly updates!
        </p>
      </div>

      <!-- CTA arrow -->
      <div class="flex-shrink-0 flex items-center gap-2 font-rounded font-semibold text-rose-600 group-hover:gap-3 transition-all min-h-[44px]">
        Follow
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14m-7-7 7 7-7 7"/>
        </svg>
      </div>
    </a>
  </div>
</section>