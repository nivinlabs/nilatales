---
/**
 * Nav.astro — sticky navigation with mobile drawer + language switcher.
 *
 * Language switcher: clay-pill toggle with "தமிழ்" and "EN" options.
 * Active language is highlighted. Clicking the inactive one navigates
 * to the equivalent page in the other language.
 */
interface Props {
  locale?: 'ta' | 'en';
}
const { locale = 'ta' } = Astro.props;

const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const navItems = [
  { href: `${prefix}/stories/`,         label: 'கதைகள்',      en: 'Stories',       emoji: '📖' },
  { href: `${prefix}/kural/`,           label: 'குறள்',        en: 'Kural',         emoji: '📜' },
  { href: `${prefix}/panchatantra/`,    label: 'பஞ்சதந்திரம்', en: 'Panchatantra',  emoji: '🦊' },
  { href: `${prefix}/comics/`,          label: 'நகைச்சுவை',   en: 'Comics',        emoji: '😄' },
  { href: `${prefix}/listen/`,          label: 'கேட்க',        en: 'Listen',        emoji: '🎧' },
  { href: `${prefix}/activities/`,      label: 'விளையாட்டு',   en: 'Activities',   emoji: '🖍️' },
];

// Language switcher: compute alternate URL
const currentPath = Astro.url.pathname;
const altPath = isEn ? (currentPath.replace(/^\/en/, '') || '/') : `/en${currentPath}`;
---

<nav
  class="sticky top-0 z-40 bg-paper-100 border-b border-paper-300"
  aria-label={isEn ? 'Main navigation' : 'பிரதான வழிசெலுத்தல்'}
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between gap-2 py-2">

      <!-- Category links (desktop) -->
      <ul class="hidden sm:flex items-center gap-1 list-none m-0 p-0" role="list">
        {navItems.map(({ href, label, en }) => (
          <li>
            <a
              href={href}
              class="flex flex-col items-center px-3 py-1 rounded-xl text-[0.7rem] font-rounded font-medium text-kohl-500 hover:text-twilight-500 hover:bg-twilight-50 transition-colors duration-150 min-h-[44px] justify-center whitespace-nowrap"
              aria-label={`${label} — ${en}`}
            >
              <span class="font-rounded-ta text-[0.75rem] leading-none">{isEn ? en : label}</span>
              <span class="text-[10px] text-paper-400 font-rounded tracking-wide mt-0.5">{isEn ? label : en}</span>
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile hamburger button -->
      <button
        id="nav-drawer-open"
        type="button"
        class="sm:hidden clay-card flex items-center justify-center w-10 h-10 rounded-xl bg-paper-50 border border-paper-300 text-kohl-700 min-h-[44px]"
        aria-label={isEn ? 'Open menu' : 'மெனுவைத் திற'}
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

      <!-- Right side: Language switcher + About + Bedtime toggle -->
      <div class="flex items-center gap-2 flex-shrink-0">

        <!-- Language switcher (clay-pill toggle) -->
        <div class="flex items-center gap-0.5 clay-card rounded-full bg-paper-50 border border-paper-300 p-0.5" role="group" aria-label="Language selector">
          <a
            href={isEn ? altPath : '#'}
            class:list={[
              'px-2.5 py-1 rounded-full text-[0.7rem] font-rounded font-semibold transition-all duration-150 min-h-[32px] flex items-center',
              !isEn
                ? 'bg-twilight-500 text-white shadow-sm'
                : 'text-kohl-500 hover:text-twilight-500'
            ]}
            aria-current={!isEn ? 'true' : undefined}
            aria-label="Tamil"
          >
            தமிழ்
          </a>
          <a
            href={isEn ? '#' : altPath}
            class:list={[
              'px-2.5 py-1 rounded-full text-[0.7rem] font-rounded font-semibold transition-all duration-150 min-h-[32px] flex items-center',
              isEn
                ? 'bg-twilight-500 text-white shadow-sm'
                : 'text-kohl-500 hover:text-twilight-500'
            ]}
            aria-current={isEn ? 'true' : undefined}
            aria-label="English"
          >
            EN
          </a>
        </div>

        <a
          href={`${prefix}/about/`}
          class="hidden md:flex px-3 py-1 rounded-xl text-[0.7rem] font-rounded font-medium text-kohl-500 hover:text-twilight-500 hover:bg-twilight-50 transition-colors duration-150 min-h-[44px] items-center justify-center"
          aria-label="About"
        >
          About
        </a>

        <!-- Bedtime Mode toggle chip -->
        <button
          id="bedtime-toggle"
          type="button"
          class="clay-card flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-paper-50 border border-paper-300 text-[0.7rem] font-rounded font-semibold text-kohl-700 hover:text-twilight-500 transition-colors duration-150 min-h-[36px]"
          aria-label={isEn ? 'Toggle Bedtime Mode' : 'இரவு பயன்முறை'}
          aria-pressed="false"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <span>Bedtime</span>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile slide-out drawer -->
  <div id="nav-drawer" class="fixed inset-0 z-50 sm:hidden hidden" role="dialog" aria-modal="true" aria-label={isEn ? 'Site menu' : 'தள மெனு'}>
    <!-- Backdrop -->
    <div id="nav-drawer-backdrop" class="absolute inset-0 bg-kohl-900/40 backdrop-blur-sm"></div>
    <!-- Drawer panel -->
    <div class="absolute top-0 left-0 w-72 max-w-[80vw] h-full bg-paper-50 border-r border-paper-300 shadow-2xl flex flex-col">
      <!-- Drawer header -->
      <div class="flex items-center justify-between px-4 py-4 border-b border-paper-200">
        <span class="font-rounded-ta text-lg font-bold text-kohl-900">நிலா கதைகள்</span>
        <button
          id="nav-drawer-close"
          type="button"
          class="clay-card flex items-center justify-center w-9 h-9 rounded-xl bg-paper-100 border border-paper-300 text-kohl-700"
          aria-label={isEn ? 'Close menu' : 'மெனுவை மூடு'}
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <!-- Language switcher in drawer -->
      <div class="px-4 py-3 border-b border-paper-200">
        <p class="font-rounded text-xs text-paper-400 mb-2">{isEn ? 'Language' : 'மொழி'}</p>
        <div class="flex items-center gap-0.5 clay-card rounded-full bg-paper-100 border border-paper-300 p-0.5 w-fit">
          <a
            href={isEn ? altPath : '#'}
            class:list={['px-3 py-1.5 rounded-full text-xs font-rounded font-semibold transition-all', !isEn ? 'bg-twilight-500 text-white' : 'text-kohl-500']}
          >
            தமிழ்
          </a>
          <a
            href={isEn ? '#' : altPath}
            class:list={['px-3 py-1.5 rounded-full text-xs font-rounded font-semibold transition-all', isEn ? 'bg-twilight-500 text-white' : 'text-kohl-500']}
          >
            English
          </a>
        </div>
      </div>
      <!-- Drawer links -->
      <ul class="flex-1 list-none m-0 p-2 overflow-y-auto">
        {navItems.map(({ href, label, en }) => (
          <li>
            <a
              href={href}
              class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-rounded font-medium text-kohl-700 hover:text-twilight-500 hover:bg-twilight-50 transition-colors duration-150 min-h-[48px]"
              aria-label={`${label} — ${en}`}
            >
              <span class="font-rounded-ta text-base">{isEn ? en : label}</span>
              <span class="text-xs text-paper-400">{isEn ? label : en}</span>
            </a>
          </li>
        ))}
        <li>
          <a
            href={`${prefix}/grownups/`}
            class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-rounded font-medium text-kohl-700 hover:text-twilight-500 hover:bg-twilight-50 transition-colors duration-150 min-h-[48px]"
          >
            <span class="font-rounded-ta text-base">{isEn ? 'For Grown-ups' : 'ஆசிரியர்'}</span>
            <span class="text-xs text-paper-400">{isEn ? 'ஆசிரியர்' : 'For Grown-ups'}</span>
          </a>
        </li>
        <li>
          <a
            href={`${prefix}/about/`}
            class="flex items-center justify-between px-4 py-3 rounded-xl text-sm font-rounded font-medium text-kohl-700 hover:text-twilight-500 hover:bg-twilight-50 transition-colors duration-150 min-h-[48px]"
          >
            <span class="font-rounded-ta text-base">{isEn ? 'About' : 'பற்றி'}</span>
            <span class="text-xs text-paper-400">{isEn ? 'பற்றி' : 'About'}</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<script>
  // Bedtime Mode: toggle dark theme
  const btn = document.getElementById('bedtime-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const active = btn.getAttribute('aria-pressed') === 'true';
      btn.setAttribute('aria-pressed', String(!active));
      document.documentElement.classList.toggle('bedtime-active', !active);
    });
  }

  // Nav active state
  const navLinks = document.querySelectorAll('nav a[href]');
  const currentPath = window.location.pathname;
  navLinks.forEach((link) => {
    const href = link.getAttribute('href') ?? '';
    if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
      link.classList.add('nav-active');
    }
  });

  // Mobile drawer
  const drawer = document.getElementById('nav-drawer');
  const openBtn = document.getElementById('nav-drawer-open');
  const closeBtn = document.getElementById('nav-drawer-close');
  const backdrop = document.getElementById('nav-drawer-backdrop');

  function openDrawer() {
    if (!drawer) return;
    drawer.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'true');
  }

  function closeDrawer() {
    if (!drawer) return;
    drawer.classList.add('hidden');
    document.body.style.overflow = '';
    if (openBtn) openBtn.setAttribute('aria-expanded', 'false');
  }

  if (openBtn) openBtn.addEventListener('click', openDrawer);
  if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
  if (backdrop) backdrop.addEventListener('click', closeDrawer);

  drawer?.querySelectorAll('a[href]').forEach((link) => {
    link.addEventListener('click', closeDrawer);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer && !drawer.classList.contains('hidden')) {
      closeDrawer();
    }
  });
</script>

<style>
  .nav-active {
    background-color: var(--color-twilight-50);
    color: var(--color-twilight-500) !important;
    box-shadow: var(--clay-pressed);
  }
</style>