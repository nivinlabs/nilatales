---
/**
 * Navbar — six public categories + brand mark + a small "For grown-ups"
 * link (hidden from the homepage tile grid per TAXONOMY.md §1).
 *
 * Sticky, translucent, blur backdrop. Active route highlighted with the
 * category's accent color (--color-* tokens).
 */

const path = Astro.url.pathname;

const pillars = [
  { href: '/stories/',    label: 'கதைகள்',     sub: 'Moral Stories',  color: 'nila'    },
  { href: '/kural/',      label: 'திருக்குறள்', sub: 'Thirukkural',    color: 'moon'    },
  { href: '/panchatantra/', label: 'பஞ்சதந்திரம்', sub: 'Panchatantra', color: 'leaf'    },
  { href: '/comics/',     label: 'நகைச்சுவை',  sub: 'Comics',         color: 'rose'    },
  { href: '/listen/',     label: 'பாடல்கள்',   sub: 'Listen',         color: 'violet'  },
  { href: '/activities/', label: 'செயல்பாடுகள்', sub: 'Activities',    color: 'sky'     },
];

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="sticky top-0 z-40 backdrop-blur-md bg-white/80 border-b border-nila-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 group" aria-label="NilaTales home">
        <span class="text-2xl moon-sparkle" aria-hidden="true">🌙</span>
        <span class="font-display font-bold text-lg text-nila-900 group-hover:text-nila-600 transition">
          நிலா கதைகள்
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-1" aria-label="Primary">
        {pillars.map((p) => (
          <a
            href={p.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-display font-medium transition',
              'hover:bg-nila-50 hover:text-nila-700',
              isActive(p.href) ? 'bg-nila-50 text-nila-700' : 'text-slate-600',
            ]}
            aria-current={isActive(p.href) ? 'page' : undefined}
          >
            {p.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <a
          href="/grownups/"
          class="hidden lg:inline-flex text-xs font-display text-slate-500 hover:text-slate-700 transition"
        >
          👨‍🏫 For grown-ups
        </a>
        <!-- Mobile menu trigger (TODO: mobile drawer) -->
        <button
          type="button"
          class="md:hidden p-2 rounded-lg hover:bg-nila-50"
          aria-label="Open menu"
          aria-expanded="false"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
