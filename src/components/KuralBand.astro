---
/**
 * KuralBand.astro — Thirukkural of the Week pull-quote section.
 *
 * Usage:
 *   <KuralBand
 *     couplet="அகர முதல..."
 *     transliteration="Aka mutal..."
 *     meaning="Letter A is first..."
 *     storyHref="/stories/thirukkural/k001-agam/"
 *   />
 *
 * DESIGN.md §6 §11.
 */
interface Props {
  couplet: string;
  transliteration?: string;
  meaning?: string;
  storyHref?: string;
  storyLabel?: string;
}
const {
  couplet,
  transliteration,
  meaning,
  storyHref,
  storyLabel = 'Read the story',
} = Astro.props;
---
<section class="py-16 md:py-24 bg-paper-200" aria-label="Thirukkural of the Week">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">

    <!-- Eyebrow -->
    <p class="eyebrow mb-6">இன்றைய குறள் · KURAL OF THE WEEK</p>

    <!-- Top rule -->
    <div class="border-t-2 border-kohl-300 mx-auto mb-8" style="max-width:120px"></div>

    <!-- Couplet — large Tamil -->
    <blockquote
      lang="ta"
      class="font-serif-ta text-[1.5rem] md:text-[1.75rem] font-normal italic leading-relaxed text-kohl-700 mb-4"
    >
      {couplet}
    </blockquote>

    <!-- Transliteration -->
    {transliteration && (
      <p class="font-mono text-sm text-kohl-500 italic tracking-wide mb-4">
        {transliteration}
      </p>
    )}

    <!-- Bottom rule -->
    <div class="border-t-2 border-kohl-300 mx-auto mt-8 mb-6" style="max-width:120px"></div>

    <!-- Meaning -->
    {meaning && (
      <p class="font-ui text-base text-kohl-500 mb-8 max-w-prose mx-auto">
        {meaning}
      </p>
    )}

    <!-- Link to story -->
    {storyHref && (
      <a
        href={storyHref}
        class="inline-flex items-center gap-2 font-ui font-semibold text-[0.875rem] text-twilight-500 hover:text-twilight-700 transition-colors duration-150 min-h-[44px] justify-center"
      >
        {storyLabel}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
    )}

  </div>
</section>
