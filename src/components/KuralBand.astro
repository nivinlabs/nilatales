---
/**
 * KuralBand.astro — Thirukkural of the Week in a clean clay card.
 */
interface Props {
  couplet: string;
  transliteration?: string;
  meaning?: string;
  storyHref?: string;
  storyLabel?: string;
}
const {
  couplet,
  transliteration,
  meaning,
  storyHref,
  storyLabel = 'Read the story',
} = Astro.props;
---
<section class="py-12 md:py-16" aria-label="Thirukkural of the Week">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">
    <div class="clay-card rounded-3xl bg-twilight-50 border border-twilight-300/30 p-8 md:p-10 text-center flex flex-col gap-5">

      <!-- Label -->
      <span class="font-rounded font-bold text-sm text-twilight-500 tracking-wide">
        இன்றைய குறள் · KURAL OF THE WEEK
      </span>

      <!-- Couplet — large Tamil -->
      <blockquote
        lang="ta"
        class="font-rounded-ta text-2xl md:text-[1.75rem] font-bold leading-relaxed text-kohl-700 m-0"
      >
        {couplet}
      </blockquote>

      <!-- Transliteration -->
      {transliteration && (
        <p class="font-mono text-sm text-kohl-500 italic tracking-wide m-0">
          {transliteration}
        </p>
      )}

      <!-- Meaning -->
      {meaning && (
        <p class="font-rounded text-base text-kohl-500 max-w-prose mx-auto m-0">
          {meaning}
        </p>
      )}

      <!-- Link to story -->
      {storyHref && (
        <a
          href={storyHref}
          class="btn-clay-primary self-center mt-2"
        >
          {storyLabel}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </a>
      )}

    </div>
  </div>
</section>