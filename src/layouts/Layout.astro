---
/**
 * Base layout for every NilaTales page.
 * Sets <html lang>, loads global styles, renders Masthead + Nav + Colophon.
 *
 * `locale` controls language: 'ta' (Tamil, default) or 'en' (English).
 * `lang` is kept for backward compat but locale takes precedence.
 */
import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Nav from '../components/Nav.astro';
import Colophon from '../components/Colophon.astro';

interface Props {
  title: string;
  description?: string;
  lang?: 'ta' | 'ta-en' | 'en';
  locale?: 'ta' | 'en';
  ogImage?: string;
  canonical?: string;
  bodyClass?: string;
  showMasthead?: boolean;
}

const {
  title,
  description = 'நிலா கதைகள் · NilaTales — Illustrated Tamil storytelling for children.',
  lang,
  locale = 'ta',
  ogImage = '/img/og-default.jpg',
  canonical,
  bodyClass = '',
  showMasthead = true,
} = Astro.props;

// locale takes precedence over lang
const htmlLang = locale === 'en' ? 'en' : (lang === 'en' ? 'en' : 'ta');
const isEn = htmlLang === 'en';

const fullTitle = title.includes('NilaTales') ? title : `${title} · ${isEn ? 'NilaTales' : 'நிலா கதைகள்'}`;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site ?? 'https://nilatales.com').toString();

// Compute alternate-language URL for hreflang
const currentPath = Astro.url.pathname;
const altPath = isEn ? currentPath.replace(/^\/en/, '') || '/' : `/en${currentPath}`;
const altURL = new URL(altPath, Astro.site ?? 'https://nilatales.com').toString();
---

<!doctype html>
<html lang={htmlLang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang: alternate language version -->
    <link rel="alternate" hreflang={isEn ? 'ta' : 'en'} href={altURL} />
    <link rel="alternate" hreflang={isEn ? 'en' : 'ta'} href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://nilatales.com').toString()} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="NilaTales" />
    <meta property="og:locale" content={isEn ? 'en_US' : 'ta_IN'} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Fraunces (display serif) + JetBrains Mono + Baloo 2 (rounded kid headings) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload critical kid-facing font (Baloo 2) for above-fold text -->
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- Noto Tamil fonts (fallback for Tamil) -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+Tamil:wght@400;500;600;700&family=Noto+Serif+Tamil:wght@400;500;600;700&display=swap"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class:list={['min-h-screen flex flex-col', bodyClass]}>
    <!-- Skip to content -->
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-paper-50 focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:text-twilight-500 focus:outline-none"
    >
      {isEn ? 'Skip to content' : 'உள்ளடக்கத்திற்குச் செல்'}
    </a>

    <!-- Brand header -->
    {showMasthead && <Masthead locale={locale} />}

    <!-- Sticky navigation -->
    <Nav locale={locale} />

    <!-- Page content -->
    <main id="main" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <Colophon locale={locale} />
  </body>
</html>