---
/**
 * AudioPost — audio playback page (lullaby, narration, song).
 *
 * Redesigned per DESIGN.md §6 Post page (Audio) + §19:
 *   - clay-raised 80px play button
 *   - Twilight header band
 *   - Lyrics panel in paper-100 card
 */
import Layout from './Layout.astro';
import { resolveCover, idBasename } from '../utils/content';
import { getEntry, type CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'audio'>;
  locale?: 'ta' | 'en';
}

const { post, locale = 'ta' } = Astro.props;
const data = post.data;

// Resolve linked story
const narrationOfEntry = data.narrationOf ? await getEntry(data.narrationOf) : null;

const coverMeta = await resolveCover(data.cover, { width: 1200 });
const durationLabel = data.durationSec
  ? `${Math.floor(data.durationSec / 60)}:${String(data.durationSec % 60).padStart(2, '0')}`
  : null;
---

<Layout
  title={data.title}
  description={data.lyrics ?? `${data.type} — ${data.title}`}
  lang={data.language === 'ta-en' ? 'ta-en' : 'ta'}
  locale={locale}
>
  <!-- ── Header ──────────────────────────── -->
  <header class="pt-10 pb-8 bg-twilight-50 border-b border-paper-300">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">

      <!-- Type badge -->
      <div class="flex items-center gap-2 mb-6">
        <span class="cat-pill cat-pill-violet">
          🎵 {data.type ?? 'Audio'}
        </span>
        {data.mood && (
          <span class="font-mono text-[0.6875rem] text-paper-400">{data.mood}</span>
        )}
        {durationLabel && (
          <span class="font-mono text-[0.6875rem] text-paper-400">{durationLabel}</span>
        )}
      </div>

      <!-- Cover art -->
      {coverMeta && coverMeta.src && (
        <div class="mb-6 flex justify-center">
          <div class="clay-comic rounded-3xl overflow-hidden w-48 h-48 relative">
            <img
              src={coverMeta.src}
              width={384}
              height={384}
              alt={data.coverAlt ?? data.title}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      )}

      <!-- Title -->
      <h1 lang="ta" class="font-display text-display font-black text-[2rem] md:text-3xl text-kohl-900 text-center leading-tight" style="font-optical-sizing:auto">
        {data.title}
      </h1>
      {data.titleEnglish && (
        <p lang="en" class="font-display italic text-lg font-light text-kohl-500 text-center mt-2">
          {data.titleEnglish}
        </p>
      )}

      <!-- Audio player with clay-raised 80px play button -->
      <div class="mt-8 p-5 rounded-2xl bg-paper-100 border border-paper-200">
        {data.audioFile ? (
          <audio
            controls
            preload="metadata"
            class="w-full"
            src={data.audioFile}
          >
            Your browser does not support the audio element.
          </audio>
        ) : (
          <div class="flex flex-col items-center gap-4 py-6 text-center">
            <!-- clay-raised play button -->
            <button
              type="button"
              class="btn-play btn-play-80 clay-raised flex items-center justify-center rounded-full"
              aria-label="Play audio"
              disabled
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true" style="margin-left:4px">
                <path d="M5 3l14 9-14 9V3z"/>
              </svg>
            </button>
            <p class="font-ui text-sm text-kohl-500">Audio coming soon</p>
          </div>
        )}
      </div>

      <!-- Narration-of link -->
      {narrationOfEntry && (
        <p class="mt-4 p-4 rounded-xl bg-paper-100 border border-paper-200 text-sm text-center">
          <span class="eyebrow block mb-1">NARRATION OF</span>
          <a
            href={`/stories/${idBasename(narrationOfEntry)}/`}
            class="font-display font-semibold text-twilight-500 hover:text-twilight-700 transition-colors"
          >
            {narrationOfEntry.data.title}
          </a>
        </p>
      )}
    </div>
  </header>

  <!-- ── Body ───────────────────────────── -->
  <article class="max-w-2xl mx-auto px-4 sm:px-6 py-12 space-y-10">

    <!-- Lyrics panel -->
    {data.lyrics && (
      <section>
        <h2 class="font-display font-bold text-[1.0625rem] text-kohl-700 mb-4">
          பாடல் வரிகள் · Lyrics
        </h2>
        <div class="p-6 rounded-2xl bg-paper-100 border border-paper-200">
          <pre lang="ta" class="whitespace-pre-wrap font-serif-ta text-[1.0625rem] text-kohl-900 leading-[1.85]">{data.lyrics}</pre>
          {data.lyricsTransliteration && (
            <details class="mt-4">
              <summary class="font-ui text-sm font-medium text-kohl-500 cursor-pointer hover:text-kohl-700 transition-colors">
                Transliteration
              </summary>
              <p lang="ta-Latn" class="mt-2 font-mono text-sm text-kohl-500 italic leading-relaxed">
                {data.lyricsTransliteration}
              </p>
            </details>
          )}
          {data.lyricsEnglish && (
            <details class="mt-3">
              <summary class="font-ui text-sm font-medium text-kohl-500 cursor-pointer hover:text-kohl-700 transition-colors">
                English meaning
              </summary>
              <p lang="en" class="mt-2 font-ui text-sm text-kohl-500 leading-relaxed">
                {data.lyricsEnglish}
              </p>
            </details>
          )}
        </div>
      </section>
    )}

    <!-- Story body slot -->
    <div class="prose-ta">
      <slot />
    </div>
  </article>
</Layout>
