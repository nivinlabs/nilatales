---
/**
 * 404 page — shown when a page doesn't exist.
 * With `serve -s`, this will be the fallback for unknown paths.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found · நிலா கதைகள்"
  description="This page could not be found."
  lang="en"
  showMasthead={true}
>
  <section class="py-20 md:py-32" aria-label="Page not found">
    <div class="max-w-xl mx-auto px-4 sm:px-6 text-center flex flex-col gap-6 items-center">

      <!-- Moon illustration -->
      <span class="clay-raised flex items-center justify-center w-20 h-20 rounded-3xl bg-twilight-50">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-twilight-500" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          <circle cx="9" cy="9" r="1" fill="currentColor"/>
          <circle cx="14" cy="14" r="0.5" fill="currentColor"/>
        </svg>
      </span>

      <div class="flex flex-col gap-2">
        <h1 class="font-rounded text-4xl md:text-5xl font-bold text-kohl-900 leading-tight">
          404
        </h1>
        <p class="font-rounded-ta text-lg text-kohl-500">
          இந்தப் பக்கம் கிடைக்கவில்லை
        </p>
        <p class="font-rounded text-base text-kohl-500">
          This page wandered off into the night sky.
        </p>
      </div>

      <a href="/" class="btn-clay-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        வீட்டிற்குத் திரும்பு · Back home
      </a>

      <!-- Quick links -->
      <div class="flex flex-wrap justify-center gap-3 mt-4">
        <a href="/stories/" class="font-rounded text-sm text-twilight-500 hover:text-twilight-700 transition-colors">Stories</a>
        <span class="text-paper-300">·</span>
        <a href="/comics/" class="font-rounded text-sm text-twilight-500 hover:text-twilight-700 transition-colors">Comics</a>
        <span class="text-paper-300">·</span>
        <a href="/listen/" class="font-rounded text-sm text-twilight-500 hover:text-twilight-700 transition-colors">Listen</a>
        <span class="text-paper-300">·</span>
        <a href="/activities/" class="font-rounded text-sm text-twilight-500 hover:text-twilight-700 transition-colors">Activities</a>
      </div>

    </div>
  </section>
</Layout>