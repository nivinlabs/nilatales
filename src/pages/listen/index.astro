---
/**
 * /listen/ — Audio index: lullabies and narrations.
 */
import Layout from '../../layouts/Layout.astro';
import CategoryHeader from '../../components/CategoryHeader.astro';
import { publishedAudio } from '../../utils/content';
import { getEntry } from 'astro:content';
import { idBasename } from '../../utils/content';

const entries = await publishedAudio();
const lullabies = entries.filter((a) => a.data.type === 'lullaby');
const narrations = entries.filter((a) => a.data.type === 'narration');
const songs = entries.filter((a) => a.data.type === 'song');

// Astro 6: reference() doesn't auto-resolve. Pre-resolve narrationOf for all.
const narrationOfTitles = new Map<string, string>();
for (const a of entries) {
  if (a.data.narrationOf && !narrationOfTitles.has(a.data.narrationOf.id)) {
    const e = await getEntry(a.data.narrationOf);
    if (e) narrationOfTitles.set(a.data.narrationOf.id, e.data.title);
  }
}

function fmt(sec: number): string {
  return `${Math.floor(sec / 60)}:${String(sec % 60).padStart(2, '0')}`;
}
---

<Layout
  title="பாடல்கள் & ஒலிக் கதைகள் · Listen"
  description="Tamil lullabies, songs, and narrated stories for bedtime and beyond."
  lang="ta"
>
  <CategoryHeader
    emoji="🎵"
    tamil="பாடல்கள் & ஒலிக் கதைகள்"
    english="Lullabies & Audio Stories"
    description="Tamil lullabies, narrated stories, and songs. Press play at bedtime — let the moon do the reading."
    accentColor="violet"
    count={entries.length}
  />

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 space-y-12">
    {entries.length === 0 ? (
      <p class="text-slate-500 italic text-center py-12">
        ஒலிக் கதைகள் விரைவில் வரும் · Audio coming soon.
      </p>
    ) : (
      <>
        {lullabies.length > 0 && (
          <div>
            <h2 class="text-xl font-display font-bold text-nila-950 mb-1">தாலாட்டு · Lullabies</h2>
            <p lang="en" class="text-sm text-slate-500 font-display italic mb-4">Cradle songs in Tamil.</p>
            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {lullabies.map((a) => (
                <li>
                  <a
                    href={`/listen/${idBasename(a)}/`}
                    class="block p-5 rounded-2xl bg-violet-50 border border-violet-100 hover:shadow-lg transition card-lift"
                  >
                    <div class="text-3xl mb-2" aria-hidden="true">🎵</div>
                    <div lang="ta" class="font-display font-semibold text-nila-950 leading-snug">{a.data.title}</div>
                    <div class="mt-2 text-xs font-display text-violet-700">{fmt(a.data.durationSec)} · {a.data.mood}</div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {narrations.length > 0 && (
          <div>
            <h2 class="text-xl font-display font-bold text-nila-950 mb-1">கதை ஒலிப்பதிவுகள் · Narrations</h2>
            <p lang="en" class="text-sm text-slate-500 font-display italic mb-4">Read-aloud versions of stories.</p>
            <ul class="space-y-2">
              {narrations.map((a) => (
                <li>
                  <a
                    href={`/listen/${idBasename(a)}/`}
                    class="flex items-center justify-between p-4 rounded-xl bg-white border border-slate-100 hover:bg-violet-50 transition"
                  >
                    <div>
                      <div lang="ta" class="font-display font-semibold text-nila-950">{a.data.title}</div>
                      {a.data.narrationOf && (
                        <div lang="ta" class="text-sm text-slate-600">
                          Narration of: {narrationOfTitles.get(a.data.narrationOf.id) ?? ''}
                        </div>
                      )}
                    </div>
                    <span class="text-xs font-display text-violet-700">{fmt(a.data.durationSec)}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {songs.length > 0 && (
          <div>
            <h2 class="text-xl font-display font-bold text-nila-950 mb-4">பாடல்கள் · Songs</h2>
            <ul class="space-y-2">
              {songs.map((a) => (
                <li>
                  <a
                    href={`/listen/${idBasename(a)}/`}
                    class="flex items-center justify-between p-4 rounded-xl bg-white border border-slate-100 hover:bg-violet-50 transition"
                  >
                    <div lang="ta" class="font-display font-semibold text-nila-950">{a.data.title}</div>
                    <span class="text-xs font-display text-violet-700">{fmt(a.data.durationSec)}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </>
    )}
  </section>
</Layout>
