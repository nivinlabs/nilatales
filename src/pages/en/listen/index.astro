---
/**
 * /en/listen/ — Audio index (English).
 */
import Layout from '../../../layouts/Layout.astro';
import CategoryHeader from '../../../components/CategoryHeader.astro';
import { publishedAudio, idBasename } from '../../../utils/content';

const entries = await publishedAudio('en');
const lullabies = entries.filter((a) => a.data.type === 'lullaby');
const narrations = entries.filter((a) => a.data.type === 'narration');
const songs = entries.filter((a) => a.data.type === 'song');
---

<Layout
  title="Listen — Lullabies & Audio Stories"
  description="Lullabies and audio stories for children — listen to Tamil bedtime songs and narrations."
  locale="en"
>
  <CategoryHeader
    emoji="🎧"
    tamil="பாடல்கள்"
    english="Listen"
    description="Lullabies, narrations, and songs — listen to bedtime stories come alive with audio."
    accentColor="violet"
    count={entries.length}
  />

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 space-y-12">
    {lullabies.length > 0 && (
      <div>
        <h2 class="font-rounded font-bold text-xl text-kohl-700 mb-4">Lullabies</h2>
        <div class="space-y-4">
          {lullabies.map((a) => (
            <a href={`/en/listen/${idBasename(a)}/`} class="clay-card flex items-center gap-4 p-4 rounded-2xl bg-paper-100 border border-paper-200 hover:border-paper-300 transition-colors group">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-violet-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--color-violet)" aria-hidden="true"><path d="M5 3l14 9-14 9V3z"/></svg>
              </div>
              <div>
                <p class="font-rounded font-bold text-sm text-kohl-700 group-hover:text-twilight-500 transition-colors">{a.data.title}</p>
                <p class="font-rounded text-xs text-paper-400">{Math.floor(a.data.durationSec / 60)} min</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {narrations.length > 0 && (
      <div>
        <h2 class="font-rounded font-bold text-xl text-kohl-700 mb-4">Narrations</h2>
        <div class="space-y-4">
          {narrations.map((a) => (
            <a href={`/en/listen/${idBasename(a)}/`} class="clay-card flex items-center gap-4 p-4 rounded-2xl bg-paper-100 border border-paper-200 hover:border-paper-300 transition-colors group">
              <div class="flex-shrink-0 w-12 h-12 rounded-full bg-violet-100 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="var(--color-violet)" aria-hidden="true"><path d="M5 3l14 9-14 9V3z"/></svg>
              </div>
              <div>
                <p class="font-rounded font-bold text-sm text-kohl-700 group-hover:text-twilight-500 transition-colors">{a.data.title}</p>
                <p class="font-rounded text-xs text-paper-400">{Math.floor(a.data.durationSec / 60)} min</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {entries.length === 0 && (
      <p class="text-slate-500 italic text-center py-12">Audio stories coming soon.</p>
    )}
  </section>
</Layout>